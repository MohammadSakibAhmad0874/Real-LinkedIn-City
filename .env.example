# ─── LinkedInCity — Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# ── BACKEND (Node.js / Hugging Face Spaces) ───────────────────────────────────

# LinkedIn OAuth app credentials (from https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# OAuth redirect URI — must exactly match what you add in LinkedIn Developer Portal
# Local dev:
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/linkedin/callback
# Production (Hugging Face Spaces):
# LINKEDIN_REDIRECT_URI=https://YOUR-HF-USERNAME-linkedincity-api.hf.space/api/linkedin/callback

# URL of your frontend — used for OAuth callback redirect
# Local dev:
FRONTEND_URL=http://localhost:3000
# Production (Vercel):
# FRONTEND_URL=https://your-app.vercel.app

# Secret key for signing session tokens (any long random string)
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Port for the Express server
PORT=4000

# ── FRONTEND (React / Vercel) ──────────────────────────────────────────────────
# Set this to your Hugging Face Spaces backend URL in Vercel dashboard.
# Leave EMPTY for local dev — Vite proxy will forward /api/* to localhost:4000.
#
# Example: VITE_API_URL=https://YOUR-HF-USERNAME-linkedincity-api.hf.space
VITE_API_URL=
